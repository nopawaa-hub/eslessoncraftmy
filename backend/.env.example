# ESLessonCraft MY — backend environment template
# Copy to `.env` for local dev, or set these in your host (e.g. Render dashboard).

# --- Database (REQUIRED in production) ---
# Local dev: mongodb://127.0.0.1:27017/lessoncraft_my
# Production (Render): use a MongoDB Atlas connection string, e.g.
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/lessoncraft_my
MONGO_URI=mongodb://127.0.0.1:27017/lessoncraft_my

# --- AI provider (REQUIRED for lesson generation) ---
AI_PROVIDER=neuralwatt
NEURALWATT_API_KEY=
NEURALWATT_BASE_URL=https://api.neuralwatt.com
NEURALWATT_MODEL=glm-5.2-short-fast

# --- Auth ---
# Random string used to sign session tokens. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Google OAuth client ID (for Google Sign-In)
GOOGLE_CLIENT_ID=

# --- Server ---
PORT=3000
NODE_ENV=development
