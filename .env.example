GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_VERSION=v1beta
GEMINI_MODEL=gemini-1.5-flash
MONGO_URI=mongodb://127.0.0.1:27017/lessoncraft_my
PORT=3000
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
SESSION_SECRET=replace_with_a_long_random_string

# NeuralWatt (GLM) provider — round-robins with Gemini when API key is set.
# Leave blank to use Gemini only.
NEURALWATT_API_KEY=your_neuralwatt_api_key_here
NEURALWATT_BASE_URL=https://api.neuralwatt.com
NEURALWATT_MODEL=glm-4-flash
